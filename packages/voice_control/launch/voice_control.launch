<launch>
  <!-- HTTP command receiver: laptop client -> HTTP POST -> /voice_control/voice_cmd -->
  <node pkg="voice_control" type="voice_command_node.py" name="voice_command_node" output="screen">
    <param name="port" value="9090" />
  </node>

  <!-- Lane follower node: camera PD control, activated by voice -->
  <node pkg="voice_control" type="lane_follower_node.py" name="lane_follower_node" output="screen">
    <param name="forward_trim" value="-0.185" />
  </node>

  <!-- Safety node: ToF obstacle detection -->
  <node pkg="voice_control" type="bot_safety_node.py" name="safety_node" output="screen" />

  <!-- Traffic light detection: camera -> stop on red/yellow, go on green -->
  <node pkg="voice_control" type="traffic_light_node.py" name="traffic_light_node" output="screen" />
</launch>
